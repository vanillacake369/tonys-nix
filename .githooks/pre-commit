#!/usr/bin/env bash
set -euo pipefail

echo "[pre-commit] Running guard tests..."
result=$(nix eval .#tests.summary --json 2>&1)
total=$(echo "$result" | jq -r .total)
passed=$(echo "$result" | jq -r .passed)

if [ "$total" != "$passed" ]; then
  echo "[FAIL] $passed/$total tests passed"
  exit 1
fi
echo "[OK] $passed/$total guard tests passed"

echo "[pre-commit] Checking nix formatting..."
if command -v alejandra &>/dev/null; then
  alejandra --check . 2>&1 | head -20 || {
    echo "[FAIL] Run 'alejandra .' to fix formatting"
    exit 1
  }
fi

echo "[pre-commit] Running statix (anti-patterns)..."
if command -v statix &>/dev/null; then
  statix check . || {
    echo "[FAIL] statix found anti-patterns — run 'statix fix .' to address them"
    exit 1
  }
else
  nix run nixpkgs#statix -- check . || {
    echo "[FAIL] statix found anti-patterns"
    exit 1
  }
fi

echo "[pre-commit] Running deadnix (unused code)..."
if command -v deadnix &>/dev/null; then
  deadnix --fail . || {
    echo "[FAIL] deadnix found unused nix code — remove the dead bindings"
    exit 1
  }
else
  nix run nixpkgs#deadnix -- --fail . || {
    echo "[FAIL] deadnix found unused nix code"
    exit 1
  }
fi

echo "[pre-commit] Running bats hook tests..."
if command -v bats &>/dev/null; then
  bats tests/hooks/*.bats || {
    echo "[FAIL] bats hook tests failed"
    exit 1
  }
else
  nix run nixpkgs#bats -- tests/hooks/*.bats || {
    echo "[FAIL] bats hook tests failed"
    exit 1
  }
fi

echo "[pre-commit] All checks passed"
