{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLI_PROXY_URL": "http://127.0.0.1:4001"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "LS(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Edit(*)",
      "Write(*)",
      "NotebookEdit(*)",
      "Task(*)",
      "Bash(*)",
      "mcp__context7",
      "mcp__playwright"
    ],
    "deny": [
      "Agent(general-purpose)"
    ],
    "ask": [],
    "disableBypassPermissionsMode": "disable"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/hooks/statusline.sh",
    "padding": 1
  },
  "subagentStatusLine": {
    "type": "command",
    "command": "~/.claude/hooks/subagent-statusline.sh"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/proxy-route.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/agent-notify.sh claude",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
