{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLI_PROXY_URL": "http://127.0.0.1:4001"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "LS(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Edit(*)",
      "Write(*)",
      "NotebookEdit(*)",
      "Task(*)",
      "Bash(*)",
      "mcp__context7",
      "mcp__playwright"
    ],
    "deny": [
      "Agent(general-purpose)"
    ],
    "ask": [],
    "disableBypassPermissionsMode": "disable"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/hooks/statusline.sh",
    "padding": 1
  },
  "subagentStatusLine": {
    "type": "command",
    "command": "~/.claude/hooks/subagent-statusline.sh"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/complexity-router.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/cmd-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/branch-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/cost-gate.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/agent-notify.sh claude",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/proxy-route.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/escalation-gate.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/test-feedback.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/escalation-gate.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-lint.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/semantic-oracle.sh",
            "timeout": 90
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/agent-notify.sh claude",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
